root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{rs,go}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# --- appended by L2 #28 on 2026-06-11 ---
[*.rs]
indent_size = 4
max_line_length = 100

[*.go]
indent_style = tab
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{toml,yaml,yml,json,html,css,scss}]
indent_size = 2

[*.{zsh,sh,bash}]
indent_size = 2

[*.{diff,patch}]
trim_trailing_whitespace = false
